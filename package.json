{
  "devDependencies": {
    "lighthouse": "^13.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "puppeteer": "^24.42.0"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2"
  },
  "scripts": {
    "build-angular:css": "npx @tailwindcss/cli -i backend/app/static/css/angular/input.css -o backend/app/static/css/angular/tailwind.css -m",
    "build-htmx:css": "npx @tailwindcss/cli -i backend/app/static/css/htmx/input.css -o backend/app/static/css/htmx/tailwind.css -m",
    "build-react:css": "npx @tailwindcss/cli -i backend/app/static/css/react/input.css -o backend/app/static/css/react/tailwind.css -m",
    "build-vue:css": "npx @tailwindcss/cli -i backend/app/static/css/vue/input.css -o backend/app/static/css/vue/tailwind.css -m",
    "dev-angular:css": "npx @tailwindcss/cli -i backend/app/static/css/angular/input.css -o backend/app/static/css/angular/tailwind.css --watch",
    "dev-htmx:css": "npx @tailwindcss/cli -i backend/app/static/css/htmx/input.css -o backend/app/static/css/htmx/tailwind.css --watch",
    "dev-react:css": "npx @tailwindcss/cli -i backend/app/static/css/react/input.css -o backend/app/static/css/react/tailwind.css --watch",
    "dev-vue:css": "npx @tailwindcss/cli -i backend/app/static/css/vue/input.css -o backend/app/static/css/vue/tailwind.css --watch",
    "format": "npx prettier . --write"
  }
}
